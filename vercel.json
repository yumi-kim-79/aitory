{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin-allow-popups"
        },
        {
          "key": "Cross-Origin-Embedder-Policy",
          "value": "unsafe-none"
        }
      ]
    }
  ],
  "crons": [
    { "path": "/api/trend/auto-publish", "schedule": "0 22 * * *" },
    { "path": "/api/cron/rss-twitter", "schedule": "0 0 * * *" }
  ]
}
